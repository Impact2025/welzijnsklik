# Neon Postgres (EU-regio — verplicht voor AVG/verwerkersovereenkomst)
# Maak een project aan op neon.tech en kies regio eu-west-1 (Frankfurt) of eu-central-1
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js — genereer met: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Resend — haal op via resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@jouwnaam.nl"

# Vercel Blob — automatisch aangemaakt via: vercel blob add
BLOB_READ_WRITE_TOKEN="vercelblob_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Demo modus — zet op true voor een openbare demo-omgeving
# DEMO_MODE=true

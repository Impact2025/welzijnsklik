generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js modellen ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Voor registratie met wachtwoord
  accounts      Account[]
  sessions      Session[]
  gebruiker     Gebruiker?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── Welzijnsklik domeinmodellen ───────────────────────────────────

enum Rol {
  COORDINATOR
  VRIJWILLIGER
  FAMILIE
}

model Organisatie {
  id        String      @id @default(cuid())
  naam      String
  plaats    String
  createdAt DateTime    @default(now())
  // Admin relations
  nieuwsbrieven       Nieuwsbrief[]
  blogPosts           BlogPost[]
  analyticsEvents     AnalyticsEvent[]
  adminInstellingen   AdminInstellingen?
  blogTags            BlogTag[]
  // Core relations
  gebruikers   Gebruiker[]
  bewoners     Bewoner[]
  hulpGevraagd HulpGevraagd[]
}

model Gebruiker {
  id            String      @id @default(cuid())
  naam          String
  email         String      @unique
  rol           Rol
  organisatieId String
  organisatie   Organisatie @relation(fields: [organisatieId], references: [id])
  telefoon      String?
  voorkeurActiviteiten String[]  @default([])
  interneNotities      String?   @db.Text
  activiteiten  Activiteit[]       @relation("VrijwilligerActiviteiten")
  familieVan    FamilieKoppeling[]
  createdAt     DateTime    @default(now())

  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  profielFoto      String?
  wervingsInteresses Wervingsinteresse[]
  emailVoorkeur    EmailVoorkeur?
  reacties         Reactie[]
  hulpReacties     HulpReactie[]
  berichtenVan     Bericht[]     @relation("BerichtenVan")
  berichtenAan     Bericht[]     @relation("BerichtenAan")
  nieuwsbriefAbonnementen NieuwsbriefAbonnement[]
  analyticsEvents AnalyticsEvent[]
  registratieTokens RegistratieToken[]

  // Intake velden voor vrijwilligers
  beschikbaarheid String?
  ervaring       String?   @db.Text
  motivatie      String?   @db.Text
  vogStatus      String?
}

model EmailVoorkeur {
  id              String   @id @default(cuid())
  gebruikerId     String   @unique
  gebruiker       Gebruiker @relation(fields: [gebruikerId], references: [id], onDelete: Cascade)
  activiteiten    Boolean  @default(true)
  wekelijkseDigest Boolean @default(true)
  gewijzigdOp     DateTime @default(now()) @updatedAt
}

model Bewoner {
  id                 String      @id @default(cuid())
  naam               String
  organisatieId      String
  organisatie        Organisatie @relation(fields: [organisatieId], references: [id])
  kamer              String?
  geboortedatum      DateTime?
  notities           String?     @db.Text
  toestemmingFotos   Boolean     @default(false)
  toestemmingDoor    String?
  toestemmingDatum   DateTime?
  activiteiten       Activiteit[]
  familieleden       FamilieKoppeling[]
  toestemmingsLog    ToestemmingLog[]
  createdAt          DateTime    @default(now())
}

model ToestemmingLog {
  id              String   @id @default(cuid())
  bewonerId       String
  bewoner         Bewoner  @relation(fields: [bewonerId], references: [id])
  actie           String
  door            String
  uitgevoerdDoor  String
  createdAt       DateTime @default(now())
}

model ToegangLog {
  id           String   @id @default(cuid())
  organisatieId String
  gebruikerId  String
  bewonerId    String?
  actie        String   @default("FOTO_BEKEKEN")
  pad          String?  @db.Text
  createdAt    DateTime @default(now())
  @@index([bewonerId])
  @@index([organisatieId])
}

model FamilieKoppeling {
  id          String    @id @default(cuid())
  bewonerId   String
  bewoner     Bewoner   @relation(fields: [bewonerId], references: [id])
  gebruikerId String
  gebruiker   Gebruiker @relation(fields: [gebruikerId], references: [id])
  relatie     String
}

model Activiteit {
  id             String    @id @default(cuid())
  bewonerId      String
  bewoner        Bewoner   @relation(fields: [bewonerId], references: [id])
  vrijwilligerId String
  vrijwilliger   Gebruiker @relation("VrijwilligerActiviteiten", fields: [vrijwilligerId], references: [id])
  type           String
  duurMinuten    Int
  notities       String?
  fotoUrl        String?
  createdAt      DateTime  @default(now())
  reacties       Reactie[]
}

model Reactie {
  id            String    @id @default(cuid())
  activiteitId  String
  activiteit    Activiteit @relation(fields: [activiteitId], references: [id], onDelete: Cascade)
  gebruikerId   String
  gebruiker     Gebruiker @relation(fields: [gebruikerId], references: [id])
  emoji         String
  bericht       String?
  createdAt     DateTime  @default(now())
  @@unique([activiteitId, gebruikerId, emoji])
}

model ActiviteitLog {
  id              String   @id @default(cuid())
  bewonerId       String
  vrijwilligerId  String
  actie           String
  details         String?
  createdAt       DateTime @default(now())
}

model HulpGevraagd {
  id             String        @id @default(cuid())
  organisatieId  String
  organisatie    Organisatie   @relation(fields: [organisatieId], references: [id])
  titel          String
  omschrijving   String        @db.Text
  datum          DateTime
  duurMinuten    Int
  aantalNodig    Int           @default(1)
  fotoUrl        String?
  status         String        @default("open")
  aangemaaktDoor String
  reacties       HulpReactie[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model HulpReactie {
  id             String       @id @default(cuid())
  hulpGevraagdId String
  hulpGevraagd   HulpGevraagd @relation(fields: [hulpGevraagdId], references: [id], onDelete: Cascade)
  vrijwilligerId String
  vrijwilliger   Gebruiker    @relation(fields: [vrijwilligerId], references: [id])
  bericht        String?
  status         String       @default("aangemeld")
  createdAt      DateTime     @default(now())
  @@unique([hulpGevraagdId, vrijwilligerId])
}

model Bericht {
  id            String    @id @default(cuid())
  organisatieId String
  vanId         String
  aanId         String
  inhoud        String    @db.Text
  gelezen       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  van           Gebruiker @relation("BerichtenVan", fields: [vanId], references: [id])
  aan           Gebruiker @relation("BerichtenAan", fields: [aanId], references: [id])
}

model Wervingsinteresse {
  id             String    @id @default(cuid())
  gebruikerId    String?
  gebruiker      Gebruiker? @relation(fields: [gebruikerId], references: [id])
  naam           String?
  email          String?
  activiteitId   String?
  bericht        String?

  // Intake details (zichtbaar voor coördinator)
  beschikbaarheid String?   // "weekend", "weekdagen", "avonden", etc.
  ervaring       String?   @db.Text  // Eerdere vrijwilligers/zorg ervaring
  motivatie      String?   @db.Text  // Waarom wil je vrijwilligerswerk doen?
  vogStatus      String?   // "heeft", "aanvraag_lopen", "niet_nodig"
  status         String    @default("nieuw")
  createdAt      DateTime  @default(now())
}


model RegistratieToken {
  id           String   @id @default(cuid())
  gebruikerId  String
  gebruiker    Gebruiker @relation(fields: [gebruikerId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  @@index([token])
}

// ─── Admin sectie modellen ───────────────────────────────────────────────

model AdminInstellingen {
  id                 String   @id @default(cuid())
  organisatieId      String   @unique
  organisatie        Organisatie @relation(fields: [organisatieId], references: [id])
  nieuwsbriefEnabled Boolean   @default(true)
  nieuwsbriefFrom    String?
  logoUrl            String?
  primaireKleur      String?
  gewijzigdOp        DateTime  @default(now()) @updatedAt
}

model Nieuwsbrief {
  id            String   @id @default(cuid())
  organisatieId String?
  organisatie   Organisatie? @relation(fields: [organisatieId], references: [id])
  onderwerp      String
  titel         String
  inhoud        String   @db.Text
  type          String   @default("nieuwsbrief")
  doelgroep     String
  status        String   @default("concept")
  verzendDatum  DateTime?
  verzondenOp   DateTime?
  verstuurtAantal Int    @default(0)
  geopendAantal   Int    @default(0)
  gekliktAantal   Int    @default(0)
  createdAt     DateTime @default(now())
  createdBy     String
  abonnementen  NieuwsbriefAbonnement[]
}

model NieuwsbriefAbonnement {
  id           String   @id @default(cuid())
  nieuwsbriefId String
  nieuwsbrief   Nieuwsbrief @relation(fields: [nieuwsbriefId], references: [id], onDelete: Cascade)
  gebruikerId String?
  gebruiker   Gebruiker? @relation(fields: [gebruikerId], references: [id])
  email       String
  naam        String?
  status      String   @default("verzonden")
  geopend     Boolean  @default(false)
  geklikt     Boolean  @default(false)
  gekliktOp   DateTime?
  createdAt   DateTime @default(now())
}

model BlogPost {
  id            String   @id @default(cuid())
  organisatieId String?
  organisatie   Organisatie? @relation(fields: [organisatieId], references: [id])
  titel         String
  slug          String   @unique
  inhoud        String   @db.Text
  samenvatting  String?  @db.Text
  seoTitle      String?
  seoDescription String?
  seoKeywords   String[] @default([])
  focusKeyword  String?
  status        String   @default("concept")
  gepubliceerdOp DateTime?
  featuredImage String?
  pageviews     Int      @default(0)
  likes         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedBy     String
  tags          BlogPostTag[]
}

model BlogTag {
  id           String   @id @default(cuid())
  organisatieId String?
  organisatie   Organisatie? @relation(fields: [organisatieId], references: [id])
  naam        String
  slug        String   @unique
  kleur       String?
  createdAt   DateTime @default(now())
  posts       BlogPostTag[]
}

model BlogPostTag {
  id     String @id @default(cuid())
  postId String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String
  tag    BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@unique([postId, tagId])
}

model Lead {
  id             String    @id @default(cuid())
  naam           String?
  organisatie    String?
  email          String
  telefoon       String?
  website        String?
  kvkNummer      String?
  sbiCode        String?
  sbiBeschrijving String?
  plaats         String?
  postcode       String?
  adres          String?
  contactPersoon String?
  notitie        String?  @db.Text
  aiScore        Int?
  aiRationale    String?
  starred        Boolean   @default(false)
  status         String    @default("nieuw") // nieuw | benaderd | klant | niet_relevant
  scrapedAt      DateTime?
  scoredAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AnalyticsEvent {
  id            String   @id @default(cuid())
  organisatieId String
  organisatie   Organisatie @relation(fields: [organisatieId], references: [id])
  eventNaam     String
  gebruikerId   String?
  gebruiker     Gebruiker? @relation(fields: [gebruikerId], references: [id])
  metaData      String?  @db.Text
  userAgent     String?
  ipHash        String?
  referrer      String?
  path          String
  createdAt     DateTime @default(now())
}
